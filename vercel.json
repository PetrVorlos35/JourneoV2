{
  "version": 2,
  "rewrites": [
    { "source": "/api/og/(.*)", "destination": "/api/og.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/share/(.*)", "destination": "/api/render.js" },
    { "source": "/dashboard/add-friend/(.*)", "destination": "/api/render.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
