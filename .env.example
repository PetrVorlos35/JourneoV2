# ── Database (MariaDB) ──
DB_HOST=db.dejny.eu
DB_USER=vorel
DB_PASSWORD=
DB_NAME=voreldb
DB_PORT=3306

# ── JWT ──
JWT_SECRET=

# ── Google OAuth ──
# Same value in both. GOOGLE_CLIENT_ID is read server-side to verify Google tokens;
# on Vercel it MUST be set as a server env var (VITE_* vars are build-time only).
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# ── Server ──
PORT=3001
